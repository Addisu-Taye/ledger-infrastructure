# .env.example
# =============================================================================
# Ledger Infrastructure - Environment Configuration Template
# Copy this file to .env and fill in your local values
# NEVER commit your actual .env file
# =============================================================================

# Database Connection (PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/ledger_dev

# Optional: Separate URL for read replicas (CQRS)
# DATABASE_READ_URL=postgresql://readonly:changeme@replica:5432/ledger_dev

# Application Settings
APP_ENV=development  # development, staging, production
LOG_LEVEL=INFO       # DEBUG, INFO, WARNING, ERROR, CRITICAL

# MCP Server Configuration
MCP_SERVER_NAME=ledger-infrastructure
MCP_TRANSPORT=stdio  # stdio, sse, or websocket

# Projection Daemon Settings
PROJECTION_POLL_INTERVAL_MS=100
PROJECTION_BATCH_SIZE=500
PROJECTION_SLO_LAG_MS=500

# Cryptographic Audit Settings
AUDIT_CHAIN_ALGORITHM=sha256
AUDIT_CHECK_INTERVAL_MINUTES=60

# Redis (Optional - for real-time projection notifications)
# REDIS_URL=redis://localhost:6379/0

# Sentry/Error Tracking (Optional)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# Feature Flags
ENABLE_OUTBOX_PATTERN=true
ENABLE_CRYPTOGRAPHIC_CHAIN=true
ENABLE_TEMPORAL_QUERIES=true